<Window x:Class="MockPaste.UI.Popup.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MockPaste.UI.Popup"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Focusable="True"
        ShowActivated="True"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <!-- Menu item template -->
        <DataTemplate x:Key="MenuItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding MnemonicKey}"
                           Foreground="{DynamicResource BrushAccent}"
                           FontWeight="SemiBold"
                           FontFamily="{StaticResource FontFamilyDefault}"
                           FontSize="{StaticResource FontSizeBase}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontFamilyDefault}"
                               FontSize="{StaticResource FontSizeBase}"/>
                    <TextBlock Text="{Binding Description}"
                               Foreground="{DynamicResource BrushTextSubtle}"
                               FontFamily="{StaticResource FontFamilyDefault}"
                               FontSize="{StaticResource FontSizeTiny}"
                               Visibility="{Binding Description, Converter={StaticResource StringToVisibility}}"/>
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="{StaticResource StringSubMenuArrow}"
                           Foreground="{DynamicResource BrushTextMuted}"
                           FontSize="{StaticResource FontSizeSubMenuArrow}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Padding="0,0,0,4"
                           Visibility="{Binding HasSubMenu, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </DataTemplate>

        <!-- History item template -->
        <DataTemplate x:Key="HistoryItemTemplate">
            <StackPanel>
                <TextBlock Text="{Binding DisplayValue}"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           FontFamily="{StaticResource FontFamilyDefault}"
                           FontSize="{StaticResource FontSizeBody}"/>
                <TextBlock Text="{Binding SubLabel}"
                           Foreground="{DynamicResource BrushTextSubtle}"
                           FontFamily="{StaticResource FontFamilyDefault}"
                           FontSize="{StaticResource FontSizeTiny}"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- Template selector -->
        <local:PopupItemTemplateSelector x:Key="PopupTemplateSelector"
                                         MenuTemplate="{StaticResource MenuItemTemplate}"
                                         HistoryTemplate="{StaticResource HistoryItemTemplate}"/>

    </Window.Resources>
    <Grid Margin="14">
        <!-- Shadow layer (blurred semi-transparent shape, no rectangular bitmap artifacts) -->
        <Border Background="{DynamicResource BrushShadow}"
                CornerRadius="8"
                Margin="3,3,0,0">
            <Border.Effect>
                <BlurEffect Radius="12"/>
            </Border.Effect>
        </Border>

        <!-- Content layer (no Effect, fast re-renders on selection change) -->
        <Border Background="{DynamicResource BrushBackground}"
                CornerRadius="8"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                MinWidth="240">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="HeaderText"
                           Grid.Column="0"
                           Text="{StaticResource StringAppName}"
                           Foreground="{DynamicResource BrushTextMuted}"
                           FontSize="{StaticResource FontSizeSmall}"
                           FontFamily="{StaticResource FontFamilyDefault}"
                           Margin="12,8,4,4"
                           VerticalAlignment="Center"
                           MouseLeftButtonUp="HeaderText_MouseLeftButtonUp"/>
                    <Button x:Name="HistoryButton"
                        Grid.Column="1"
                        Margin="0,4,8,0"
                        Padding="8,2"
                        Foreground="{DynamicResource BrushTextSubtle}"
                        FontFamily="{StaticResource FontFamilyDefault}"
                        FontSize="{StaticResource FontSizeTiny}"
                        Cursor="Hand"
                        VerticalAlignment="Top"
                        Click="HistoryButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                    Background="Transparent"
                                    CornerRadius="3"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource BrushSurface}"/>
                                        <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="{StaticResource StringButtonHistory}" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- Separator -->
                <Rectangle Grid.Row="1" Height="1" Fill="{DynamicResource BrushBorder}" Margin="8,4"/>

                <!-- Empty history state -->
                <TextBlock x:Name="EmptyHistoryText"
                       Grid.Row="2"
                       Text="{StaticResource StringEmptyHistory}"
                       Foreground="{DynamicResource BrushTextSubtle}"
                       FontFamily="{StaticResource FontFamilyDefault}"
                       FontSize="{StaticResource FontSizeBody}"
                       HorizontalAlignment="Center"
                       Margin="12,16"
                       Visibility="Collapsed"/>

                <!-- Menu Items -->
                <ListBox x:Name="MenuList"
                     Grid.Row="3"
                     Background="Transparent"
                     BorderThickness="0"
                     FocusVisualStyle="{x:Null}"
                     Margin="4"
                     MaxHeight="280"
                     SelectionMode="Single"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ItemTemplateSelector="{StaticResource PopupTemplateSelector}"
                     KeyDown="MenuList_KeyDown"
                     MouseLeftButtonUp="MenuList_MouseLeftButtonUp">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                            Background="Transparent"
                                            CornerRadius="4"
                                            Padding="12,6"
                                            Margin="0,2"
                                            Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BrushSurface}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BrushSurfaceSelected}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Focusable" Value="True"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>