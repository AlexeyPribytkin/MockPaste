<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Font family -->
    <FontFamily x:Key="FontFamilyDefault">Segoe UI</FontFamily>

    <!-- Font size scale -->
    <sys:Double x:Key="FontSizeTiny">10</sys:Double>
    <sys:Double x:Key="FontSizeSmall">11</sys:Double>
    <sys:Double x:Key="FontSizeBody">12</sys:Double>
    <sys:Double x:Key="FontSizeBase">13</sys:Double>
    <sys:Double x:Key="FontSizeSubMenuArrow">16</sys:Double>
    <sys:Double x:Key="FontSizeMenu">14</sys:Double>
    <sys:Double x:Key="FontSizeLarge">20</sys:Double>

</ResourceDictionary>
