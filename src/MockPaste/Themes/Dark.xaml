<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Application background -->
    <SolidColorBrush x:Key="BrushBackground"          Color="#FF1E1E2E"/>

    <!-- Surface layers -->
    <SolidColorBrush x:Key="BrushSurface"             Color="#FF2A2A3C"/>
    <SolidColorBrush x:Key="BrushSurfaceSelected"     Color="#FF3A3A5C"/>

    <!-- Borders and dividers -->
    <SolidColorBrush x:Key="BrushBorder"              Color="#FF3A3A4C"/>

    <!-- Accent (primary purple) -->
    <SolidColorBrush x:Key="BrushAccent"              Color="#FF7C3AED"/>
    <SolidColorBrush x:Key="BrushAccentHover"         Color="#FF9055FF"/>

    <!-- Secondary button hover -->
    <SolidColorBrush x:Key="BrushSecondaryButtonHover" Color="#FF4A4A5C"/>

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="BrushScrollThumb"         Color="#FF4A4A6A"/>
    <SolidColorBrush x:Key="BrushScrollThumbHover"    Color="#FF6A6A9A"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="BrushTextPrimary"         Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="BrushTextMuted"           Color="#FFB0B0C0"/>
    <SolidColorBrush x:Key="BrushTextSubtle"          Color="#FF808090"/>

    <!-- Toggle switch -->
    <SolidColorBrush x:Key="BrushToggleTrackOff"      Color="#FF3D3D42"/>
    <SolidColorBrush x:Key="BrushToggleTrackBorder"   Color="#A0FFFFFF"/>
    <SolidColorBrush x:Key="BrushToggleHover"         Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="BrushToggleThumbOff"      Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="BrushToggleThumbOn"       Color="#FF000000"/>

    <!-- Validation error -->
    <SolidColorBrush x:Key="BrushError"               Color="#FFE05555"/>

    <!-- Shadow overlay -->
    <SolidColorBrush x:Key="BrushShadow"              Color="#50000000"/>

</ResourceDictionary>
