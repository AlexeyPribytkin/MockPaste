<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Shared application name -->
    <sys:String x:Key="StringAppName">MockPaste</sys:String>

    <!-- Popup window -->
    <sys:String x:Key="StringButtonHistory">History</sys:String>
    <sys:String x:Key="StringEmptyHistory">No recent items</sys:String>
    <sys:String x:Key="StringSubMenuArrow">›</sys:String>

    <!-- Settings window -->
    <sys:String x:Key="StringSettingsTitle">MockPaste — Settings</sys:String>
    <sys:String x:Key="StringSettingsHeader">Settings</sys:String>
    <sys:String x:Key="StringLabelHotkey">Global Hotkey</sys:String>
    <sys:String x:Key="StringHotkeyDefault">Ctrl + Alt + Space</sys:String>
    <sys:String x:Key="StringButtonChange">Change</sys:String>
    <sys:String x:Key="StringButtonReset">Reset</sys:String>
    <sys:String x:Key="StringCheckboxPreserveClipboard">Preserve clipboard content</sys:String>
    <sys:String x:Key="StringLabelPasteDelay">Paste delay:</sys:String>
    <sys:String x:Key="StringUnitMilliseconds">ms</sys:String>
    <sys:String x:Key="StringCheckboxLaunchAtStartup">Launch at system startup</sys:String>
    <sys:String x:Key="StringLabelHistorySize">History size:</sys:String>
    <sys:String x:Key="StringUnitItems">items</sys:String>
    <sys:String x:Key="StringButtonSave">Save</sys:String>
    <sys:String x:Key="StringButtonCancel">Cancel</sys:String>
    <sys:String x:Key="StringTooltipClose">Close</sys:String>

    <!-- Settings section headers -->
    <sys:String x:Key="StringSectionHotkey">HOTKEY</sys:String>
    <sys:String x:Key="StringSectionBehavior">BEHAVIOR</sys:String>
    <sys:String x:Key="StringSectionGeneral">GENERAL</sys:String>
    <sys:String x:Key="StringSectionAppearance">APPEARANCE</sys:String>

    <!-- Theme -->
    <sys:String x:Key="StringLabelTheme">Theme:</sys:String>
    <sys:String x:Key="StringThemeDark">Dark</sys:String>
    <sys:String x:Key="StringThemeLight">Light</sys:String>
    <sys:String x:Key="StringThemeSystem">System</sys:String>

    <!-- Status messages (set from code) -->
    <sys:String x:Key="StringStatusCapturePrompt">Press a key combination...</sys:String>
    <sys:String x:Key="StringStatusHotkeySet">Hotkey set to: {0}</sys:String>
    <sys:String x:Key="StringStatusHotkeyReset">Hotkey reset to default.</sys:String>
    <sys:String x:Key="StringStatusHotkeyModifierRequired">At least one modifier key (Ctrl, Alt, Shift, Win) is required.</sys:String>
    <sys:String x:Key="StringStatusSaved">Settings saved.</sys:String>
    <sys:String x:Key="StringStatusSaveFailed">Failed to save settings.</sys:String>

    <!-- Discard-changes confirmation dialog -->
    <sys:String x:Key="StringDiscardChangesMessage">Discard unsaved changes?</sys:String>

</ResourceDictionary>
