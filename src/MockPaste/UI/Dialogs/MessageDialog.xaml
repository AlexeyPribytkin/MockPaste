<Window x:Class="MockPaste.UI.Dialogs.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MockPaste"
        Width="360"
        SizeToContent="Height"
        MinHeight="140"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource BrushTextPrimary}"
        FontFamily="{StaticResource FontFamilyDefault}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="46" GlassFrameThickness="0" ResizeBorderThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid Margin="12">
        <!-- Shadow layer -->
        <Border Background="{DynamicResource BrushShadow}"
                CornerRadius="8"
                Margin="3,3,0,0">
            <Border.Effect>
                <BlurEffect Radius="12"/>
            </Border.Effect>
        </Border>

        <!-- Content layer -->
        <Border Background="{DynamicResource BrushBackground}"
                CornerRadius="8"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1">
            <DockPanel>

                <!-- Custom title bar -->
                <Grid DockPanel.Dock="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="TitleText"
                        Grid.Column="0"
                        Foreground="{DynamicResource BrushTextMuted}"
                        FontSize="{StaticResource FontSizeBase}"
                        FontFamily="{StaticResource FontFamilyDefault}"
                        Margin="12,6,4,4"/>
                    <Button
                        Grid.Column="2"
                        Content="✕"
                        Style="{StaticResource TitleBarButtonStyle}"
                        Click="Close_Click"/>
                </Grid>

                <!-- Body -->
                <StackPanel Margin="20,8,20,20">

                    <!-- Icon + message row -->
                    <Grid Margin="0,4,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="IconText"
                            Grid.Column="0"
                            FontSize="22"
                            VerticalAlignment="Top"
                            Margin="0,2,12,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="ℹ"/>
                                    <Setter Property="Foreground" Value="{DynamicResource BrushAccent}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="Error">
                                            <Setter Property="Text" Value="✖"/>
                                            <Setter Property="Foreground" Value="{DynamicResource BrushError}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="Warning">
                                            <Setter Property="Text" Value="⚠"/>
                                            <Setter Property="Foreground" Value="{DynamicResource BrushAccentHover}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="Question">
                                            <Setter Property="Text" Value="?"/>
                                            <Setter Property="Foreground" Value="{DynamicResource BrushAccent}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock
                            x:Name="MessageText"
                            Grid.Column="1"
                            FontSize="{StaticResource FontSizeBase}"
                            Foreground="{DynamicResource BrushTextPrimary}"
                            TextWrapping="Wrap"
                            VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Buttons row -->
                    <Grid x:Name="ButtonRow">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Yes / OK button (accent) -->
                        <Button
                            x:Name="YesButton"
                            Grid.Column="1"
                            MinWidth="80"
                            Padding="14,8"
                            Click="Yes_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                    <Setter Property="Content" Value="{StaticResource StringDialogOK}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="Question">
                                            <Setter Property="Content" Value="{StaticResource StringDialogYes}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- No / Cancel button (secondary) -->
                        <Button
                            x:Name="NoButton"
                            Grid.Column="3"
                            MinWidth="80"
                            Padding="14,8"
                            Click="No_Click">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Content" Value="{StaticResource StringDialogNo}"/>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Window}}" Value="Question">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>

            </DockPanel>
        </Border>
    </Grid>
</Window>
