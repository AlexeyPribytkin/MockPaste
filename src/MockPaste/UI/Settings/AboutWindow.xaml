<Window x:Class="MockPaste.UI.Settings.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:MockPaste.Localization"
        Title="{loc:Loc StringAboutTitle}"
        Width="644"
        Height="564"
        MinWidth="400"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource BrushTextPrimary}"
        FontFamily="{StaticResource FontFamilyDefault}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="46" GlassFrameThickness="0" ResizeBorderThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid Margin="12">
        <!-- Drop shadow -->
        <Border Background="{DynamicResource BrushShadow}"
                CornerRadius="8"
                Margin="3,3,0,0">
            <Border.Effect>
                <BlurEffect Radius="12"/>
            </Border.Effect>
        </Border>

        <Border Background="{DynamicResource BrushBackground}"
                CornerRadius="8"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1">
            <DockPanel>

                <!-- Title bar -->
                <Grid DockPanel.Dock="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Text="{loc:Loc StringAboutTitle}"
                        Foreground="{DynamicResource BrushTextMuted}"
                        FontSize="{StaticResource FontSizeBase}"
                        FontFamily="{StaticResource FontFamilyDefault}"
                        Margin="12,6,4,4"/>

                    <Button
                        Grid.Column="2"
                        Content="{loc:Loc StringCloseGlyph}"
                        Style="{StaticResource TitleBarButtonStyle}"
                        ToolTip="{loc:Loc StringTooltipClose}"
                        Click="Close_Click"/>
                </Grid>

                <!-- Main content + bottom buttons -->
                <Grid Margin="24,4,16,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- App info header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock
                            Text="{loc:Loc StringAppName}"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Margin="0,0,0,8"/>

                        <TextBlock
                            x:Name="VersionText"
                            FontSize="{StaticResource FontSizeBase}"
                            Foreground="{DynamicResource BrushTextMuted}"
                            Margin="0,0,0,2"/>

                        <TextBlock
                            Text="{loc:Loc StringAboutCopyright}"
                            FontSize="{StaticResource FontSizeBase}"
                            Foreground="{DynamicResource BrushTextMuted}"
                            Margin="0,0,0,2"/>

                        <TextBlock
                            Text="{loc:Loc StringAboutLicense}"
                            FontSize="{StaticResource FontSizeBase}"
                            Foreground="{DynamicResource BrushTextMuted}"/>
                    </StackPanel>

                    <!-- Separator below header -->
                    <Border Grid.Row="1"
                            Height="1"
                            Background="{DynamicResource BrushBorder}"
                            Margin="0,0,0,10"/>

                    <!-- Scrollable license content -->
                    <ScrollViewer
                        Grid.Row="2"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Padding="0,0,4,8">
                        <RichTextBox
                            x:Name="LicenseContent"
                            IsReadOnly="True"
                            BorderThickness="0"
                            Background="Transparent"
                            Foreground="{DynamicResource BrushTextMuted}"
                            FontSize="{StaticResource FontSizeBase}"
                            FontFamily="{StaticResource FontFamilyDefault}"
                            IsDocumentEnabled="True"
                            Padding="0"
                            IsTabStop="False"/>
                    </ScrollViewer>

                    <!-- Bottom buttons -->
                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Button
                            x:Name="GitHubButton"
                            Content="{loc:Loc StringButtonGitHub}"
                            MinWidth="80"
                            Padding="16,8"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="GitHub_Click"/>

                        <Button
                            Content="{loc:Loc StringButtonClose}"
                            MinWidth="80"
                            Padding="16,8"
                            HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="Close_Click"/>
                    </Grid>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
