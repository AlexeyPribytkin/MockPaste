<Window x:Class="MockPaste.UI.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:components="clr-namespace:MockPaste.UI.Components"
        xmlns:comp="clr-namespace:MockPaste.UI.Components"
        xmlns:loc="clr-namespace:MockPaste.Localization"
        Title="{loc:Loc StringSettingsTitle}"
        Width="420"
        Height="588"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource BrushTextPrimary}"
        FontFamily="{StaticResource FontFamilyDefault}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="46" GlassFrameThickness="0" ResizeBorderThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Segmented theme pill -->
        <Style x:Key="ThemeSegmentStyle" TargetType="RadioButton">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeBase}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="4"
                                Padding="12,6" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource BrushSecondaryButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource BrushAccent}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <!-- Shadow layer -->
        <Border Background="{DynamicResource BrushShadow}"
                CornerRadius="8"
                Margin="3,3,0,0">
            <Border.Effect>
                <BlurEffect Radius="12"/>
            </Border.Effect>
        </Border>

        <!-- Content layer (no Effect, fast re-renders on selection change) -->
        <Border Background="{DynamicResource BrushBackground}"
                CornerRadius="8"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1">
            <DockPanel>

                <!-- Custom title bar -->
                <Grid DockPanel.Dock="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="{loc:Loc StringSettingsTitle}"
                        Foreground="{DynamicResource BrushTextMuted}"
                        FontSize="{StaticResource FontSizeBase}"
                        FontFamily="{StaticResource FontFamilyDefault}"
                        Margin="12,6,4,4"/>
                    <Button
                        Grid.Column="2"
                        Content="{loc:Loc StringCloseGlyph}"
                        Style="{StaticResource TitleBarButtonStyle}"
                        ToolTip="{loc:Loc StringTooltipClose}"
                        Click="TitleBarClose_Click"/>
                </Grid>

                <Grid Margin="24,4,16,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock
                        Grid.Row="0"
                        Text="{loc:Loc StringSettingsHeader}"
                        FontWeight="SemiBold"/>

                    <!-- Scrollable content -->
                    <ScrollViewer
                        Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        Focusable="False"
                        Padding="0,0,8,0">

                        <StackPanel>
                            <!-- ── HOTKEY ── -->
                            <Grid Margin="0,16,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="{loc:Loc StringSectionHotkey}"
                                    Foreground="{DynamicResource BrushTextMuted}"
                                    FontSize="{StaticResource FontSizeSmall}"
                                    FontWeight="SemiBold"/>
                                <Rectangle
                                    Grid.Column="1"
                                    Height="1" Fill="{DynamicResource BrushBorder}"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock
                                Text="{loc:Loc StringLabelHotkey}"
                                Foreground="{DynamicResource BrushTextMuted}"
                                FontSize="{StaticResource FontSizeBody}"
                                Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border
                                    Background="{DynamicResource BrushSurface}"
                                    CornerRadius="4"
                                    Padding="10,8"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1">

                                    <TextBlock
                                        x:Name="HotkeyDisplay"
                                        Text="{Binding HotkeyDisplayText}"
                                        FontSize="{StaticResource FontSizeBase}"/>
                                </Border>

                                <Button
                                    x:Name="ChangeHotkeyButton"
                                    Grid.Column="1"
                                    Command="{Binding ChangeHotkeyCommand}"
                                    Margin="8,0,0,0"
                                    Padding="12,8">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                            <Setter Property="Content" Value="{loc:Loc StringButtonChange}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                                    <Setter Property="Content" Value="{loc:Loc StringButtonCancel}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button
                                    Grid.Column="2"
                                    Content="{loc:Loc StringButtonReset}"
                                    Command="{Binding ResetHotkeyCommand}"
                                    Margin="8,0,0,0"
                                    Padding="12,8"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                            </Grid>

                            <!-- ── BEHAVIOR ── -->
                            <Grid Margin="0,16,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Text="{loc:Loc StringSectionBehavior}"
                                    Foreground="{DynamicResource BrushTextMuted}"
                                    FontSize="{StaticResource FontSizeSmall}"
                                    FontWeight="SemiBold"/>

                                <Rectangle
                                    Grid.Column="1"
                                    Height="1"
                                    Fill="{DynamicResource BrushBorder}"
                                    Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </Grid>

                            <components:ToggleSwitch
                                x:Name="PreserveClipboardCheck"
                                Header="{loc:Loc StringCheckboxPreserveClipboard}"
                                Foreground="{DynamicResource BrushTextPrimary}"
                                FontSize="{StaticResource FontSizeBase}"
                                Margin="0,0,0,12"
                                IsChecked="{Binding PreserveClipboard, Mode=TwoWay}"/>

                            <components:ToggleSwitch
                                x:Name="TrackClipboardHistoryCheck"
                                Header="{loc:Loc StringCheckboxTrackClipboardHistory}"
                                Foreground="{DynamicResource BrushTextPrimary}"
                                FontSize="{StaticResource FontSizeBase}"
                                Margin="0,0,0,12"
                                IsChecked="{Binding TrackClipboardHistory, Mode=TwoWay}"/>

                            <comp:LabeledSlider
                                Minimum="0"
                                Maximum="500"
                                TickFrequency="50"
                                SmallChange="10"
                                LargeChange="50"
                                Value="{Binding PasteDelay, Mode=TwoWay}"
                                Header="{loc:Loc StringLabelPasteDelay}"
                                ValueDisplay="{Binding PasteDelayDisplay}"
                                Margin="0,0,0,0"/>

                            <!-- ── GENERAL ── -->
                            <Grid Margin="0,16,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Text="{loc:Loc StringSectionGeneral}"
                                    Foreground="{DynamicResource BrushTextMuted}"
                                    FontSize="{StaticResource FontSizeSmall}"
                                    FontWeight="SemiBold"/>

                                <Rectangle
                                    Grid.Column="1"
                                    Height="1"
                                    Fill="{DynamicResource BrushBorder}"
                                    Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </Grid>

                            <components:ToggleSwitch
                                x:Name="LaunchStartupCheck"
                                Header="{loc:Loc StringCheckboxLaunchAtStartup}"
                                Foreground="{DynamicResource BrushTextPrimary}"
                                FontSize="{StaticResource FontSizeBase}"
                                Margin="0,0,0,12"
                                IsChecked="{Binding LaunchAtStartup, Mode=TwoWay}"/>

                            <comp:LabeledSlider
                                Minimum="1"
                                Maximum="500"
                                TickFrequency="50"
                                SmallChange="1"
                                LargeChange="10"
                                Value="{Binding HistorySize, Mode=TwoWay}"
                                Header="{loc:Loc StringLabelHistorySize}"
                                ValueDisplay="{Binding HistorySizeDisplay}"
                                Margin="0,0,0,0"/>

                            <!-- ── APPEARANCE ── -->
                            <Grid Margin="0,16,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Text="{loc:Loc StringSectionAppearance}"
                                    Foreground="{DynamicResource BrushTextMuted}"
                                    FontSize="{StaticResource FontSizeSmall}"
                                    FontWeight="SemiBold"/>

                                <Rectangle
                                    Grid.Column="1"
                                    Height="1"
                                    Fill="{DynamicResource BrushBorder}"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock
                                Text="{loc:Loc StringLabelTheme}"
                                Foreground="{DynamicResource BrushTextMuted}"
                                FontSize="{StaticResource FontSizeBody}"
                                Margin="0,0,0,8"/>

                            <!-- Segmented theme selector -->
                            <Border
                                Background="{DynamicResource BrushSurface}"
                                CornerRadius="6"
                                Padding="3"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1">

                                <UniformGrid Columns="3">
                                    <RadioButton
                                        x:Name="ThemeDark"
                                        Style="{StaticResource ThemeSegmentStyle}"
                                        GroupName="ThemeGroup"
                                        Tag="Dark"
                                        IsChecked="{Binding IsThemeDark, Mode=TwoWay}"
                                        Content="{loc:Loc StringThemeDark}"
                                        Margin="2,0"/>
                                    <RadioButton
                                        x:Name="ThemeLight"
                                        Style="{StaticResource ThemeSegmentStyle}"
                                        GroupName="ThemeGroup"
                                        Tag="Light"
                                        IsChecked="{Binding IsThemeLight, Mode=TwoWay}"
                                        Content="{loc:Loc StringThemeLight}"
                                        Margin="2,0"/>
                                    <RadioButton
                                        x:Name="ThemeSystem"
                                        Style="{StaticResource ThemeSegmentStyle}"
                                        GroupName="ThemeGroup"
                                        Tag="System"
                                        IsChecked="{Binding IsThemeSystem, Mode=TwoWay}"
                                        Content="{loc:Loc StringThemeSystem}"
                                        Margin="2,0"/>
                                </UniformGrid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Status -->
                    <TextBlock
                        x:Name="StatusText"
                        Grid.Row="2"
                        Text="{Binding StatusMessage}"
                        Foreground="{DynamicResource BrushTextMuted}"
                        FontSize="{StaticResource FontSizeSmall}" Margin="0,12,0,0"/>

                    <!-- About / Save / Cancel -->
                    <Grid
                        Grid.Row="3"
                        Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Content="{loc:Loc StringButtonAbout}"
                            MinWidth="80"
                            Padding="16,8"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="About_Click"/>

                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                            <Button
                                x:Name="SaveButton"
                                Content="{loc:Loc StringButtonSave}"
                                Padding="16,8"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{Binding SaveCommand}"
                                Margin="0,0,8,0"/>

                            <Button
                                Content="{loc:Loc StringButtonCancel}"
                                Padding="16,8"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="Cancel_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>