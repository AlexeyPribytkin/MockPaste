<Window x:Class="MockPaste.UI.Popup.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MockPaste.UI.Popup"
        xmlns:converters="clr-namespace:MockPaste.UI.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Focusable="True"
        ShowActivated="True"
        Deactivated="Window_Deactivated">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- Menu item template -->
        <DataTemplate x:Key="MenuItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding MnemonicKey}"
                           Foreground="{DynamicResource BrushAccent}"
                           FontWeight="SemiBold"
                           FontFamily="{StaticResource FontFamilyDefault}"
                           FontSize="{StaticResource FontSizeBase}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontFamilyDefault}"
                               FontSize="{StaticResource FontSizeBase}"/>
                    <TextBlock Text="{Binding Description}"
                               Foreground="{DynamicResource BrushTextSubtle}"
                               FontFamily="{StaticResource FontFamilyDefault}"
                               FontSize="{StaticResource FontSizeTiny}"
                               Visibility="{Binding Description, Converter={StaticResource StringToVisibility}}"/>
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Text="{StaticResource StringSubMenuArrow}"
                           Foreground="{DynamicResource BrushTextMuted}"
                           FontSize="{StaticResource FontSizeSubMenuArrow}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Padding="0,0,0,4"
                           Visibility="{Binding HasSubMenu, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </DataTemplate>

        <!-- History item template -->
        <DataTemplate x:Key="HistoryItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayValue}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               FontFamily="{StaticResource FontFamilyDefault}"
                               FontSize="{StaticResource FontSizeBody}"/>
                    <TextBlock Text="{Binding SubLabel}"
                               Foreground="{DynamicResource BrushTextSubtle}"
                               FontFamily="{StaticResource FontFamilyDefault}"
                               FontSize="{StaticResource FontSizeTiny}"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding DeleteCommand}"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        Padding="4,2"
                        ToolTip="{StaticResource StringTooltipDeleteHistoryItem}"
                        Tag="DeleteBtn"
                        Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="Transparent"
                                    CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <!-- Bin icon as a Path so Foreground drives its color in any theme -->
                                <Viewbox Width="11" Height="11" VerticalAlignment="Center">
                                    <Path x:Name="icon"
                                          Data="M3,1 L3,0 L7,0 L7,1 L10,1 L10,2 L0,2 L0,1 Z
                                                M1,3 L9,3 L8.5,10 L1.5,10 Z
                                                M4,4 L4,9 M6,4 L6,9"
                                          Fill="{DynamicResource BrushTextMuted}"
                                          Stroke="{DynamicResource BrushTextMuted}"
                                          StrokeThickness="0.3"
                                          Visibility="Hidden"/>
                            </Viewbox>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                    <Setter TargetName="icon" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                    <Setter TargetName="icon" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="icon" Property="Fill" Value="{DynamicResource BrushError}"/>
                                    <Setter TargetName="icon" Property="Stroke" Value="{DynamicResource BrushError}"/>
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource BrushSurface}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </DataTemplate>

        <!-- Template selector -->
        <local:PopupItemTemplateSelector x:Key="PopupTemplateSelector"
                                         MenuTemplate="{StaticResource MenuItemTemplate}"
                                         HistoryTemplate="{StaticResource HistoryItemTemplate}"/>

    </Window.Resources>
    <Grid Margin="12">
        <!-- Shadow layer (blurred semi-transparent shape, no rectangular bitmap artifacts) -->
        <Border Background="{DynamicResource BrushShadow}"
                CornerRadius="8"
                Margin="3,3,0,0">
            <Border.Effect>
                <BlurEffect Radius="12"/>
            </Border.Effect>
        </Border>

        <!-- Content layer (no Effect, fast re-renders on selection change) -->
        <Border Background="{DynamicResource BrushBackground}"
                CornerRadius="8"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                MinWidth="240">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0"
                      MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="HeaderText"
                           Grid.Column="0"
                           Text="{Binding HeaderText}"
                           Foreground="{DynamicResource BrushTextMuted}"
                           FontSize="{StaticResource FontSizeBase}"
                           FontFamily="{StaticResource FontFamilyDefault}"
                           Margin="12,6,4,4"
                           MouseLeftButtonUp="HeaderText_MouseLeftButtonUp"/>
                    <Button x:Name="HistoryButton"
                            Grid.Column="1"
                            Margin="0,4,4,0"
                            Padding="8,2"
                            Foreground="{DynamicResource BrushTextSubtle}"
                            FontFamily="{StaticResource FontFamilyDefault}"
                            FontSize="{StaticResource FontSizeBody}"
                            Visibility="{Binding IsHistoryButtonVisible, Converter={StaticResource BoolToVisibility}}"
                            Cursor="Hand"
                            Click="HistoryButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                    Background="Transparent"
                                    CornerRadius="3"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="true">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource BrushSurface}"/>
                                        <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="{StaticResource StringButtonHistory}" Margin="0,-1,0,0"/>
                    </Button>
                </Grid>

                <!-- Separator -->
                <Rectangle Grid.Row="1" Height="1" Fill="{DynamicResource BrushBorder}" Margin="8,4"/>

                <!-- Empty history state -->
                <TextBlock x:Name="EmptyHistoryText"
                       Grid.Row="2"
                       Text="{StaticResource StringEmptyHistory}"
                       Foreground="{DynamicResource BrushTextSubtle}"
                       FontFamily="{StaticResource FontFamilyDefault}"
                       FontSize="{StaticResource FontSizeBody}"
                       HorizontalAlignment="Center"
                       Margin="12,16"
                       Visibility="{Binding IsEmptyHistoryVisible, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Menu Items -->
                <ListBox x:Name="MenuList"
                     Grid.Row="3"
                     Background="Transparent"
                     BorderThickness="0"
                     FocusVisualStyle="{x:Null}"
                     Margin="4,2"
                     MaxHeight="280"
                     SelectionMode="Single"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ItemTemplateSelector="{StaticResource PopupTemplateSelector}"
                     ItemsSource="{Binding Items}"
                     SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                     KeyDown="MenuList_KeyDown"
                     MouseLeftButtonUp="MenuList_MouseLeftButtonUp">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                            Background="Transparent"
                                            CornerRadius="4"
                                            Padding="12,6"
                                            Margin="0,2"
                                            Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BrushSurface}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BrushSurfaceSelected}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Focusable" Value="True"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>