<UserControl x:Class="MockPaste.UI.Components.ToggleSwitch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:self="clr-namespace:MockPaste.UI.Components"
             Focusable="True"
             IsTabStop="True"
             SnapsToDevicePixels="True"
             KeyDown="OnKeyDown"
             MouseLeftButtonUp="OnMouseLeftButtonUp">

    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="FocusVisualStyle" Value="{DynamicResource {x:Static SystemParameters.FocusVisualStyleKey}}"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType={x:Type self:ToggleSwitch}}}" Value="False">
                        <Setter Property="Cursor" Value="Arrow"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Label -->
        <ContentPresenter Grid.Column="0"
                          Content="{Binding Header, RelativeSource={RelativeSource AncestorType={x:Type self:ToggleSwitch}}}"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"/>

        <!-- State label -->
        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource BrushTextMuted}"
                   FontSize="{StaticResource FontSizeSmall}"
                   FontWeight="SemiBold">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="{StaticResource StringToggleOff}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType={x:Type self:ToggleSwitch}}}" Value="True">
                            <Setter Property="Text" Value="{StaticResource StringToggleOn}"/>
                            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Switch track + thumb -->
        <Grid Grid.Column="2" Width="40" Height="20" VerticalAlignment="Center">
            <!-- Off-state track (always behind) -->
            <Border x:Name="OffTrack"
                    CornerRadius="10"
                    Background="{DynamicResource BrushToggleTrackOff}"
                    BorderBrush="{DynamicResource BrushToggleTrackBorder}"
                    BorderThickness="1"/>

            <!-- On-state track (accent, fades in when checked) -->
            <Border x:Name="OnTrack" CornerRadius="10"
                    Background="{DynamicResource BrushAccent}"
                    Opacity="0"/>

            <!-- Hover overlay -->
            <Border x:Name="HoverOverlay" CornerRadius="10"
                    Background="{DynamicResource BrushToggleHover}"
                    Opacity="0"/>

            <!-- Thumb container: owns the position (translate) animation -->
            <Grid x:Name="ThumbHost"
                  Width="12" Height="12"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center"
                  Margin="3.3,0,0,0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ThumbTransform" X="0"/>
                </Grid.RenderTransform>
                <!-- Thumb circle: grows from its own centre on hover -->
                <Ellipse x:Name="Thumb"
                         Width="12" Height="12">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource BrushToggleThumbOn}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType={x:Type self:ToggleSwitch}}}" Value="False">
                                    <Setter Property="Fill" Value="{DynamicResource BrushToggleThumbOff}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                    <Ellipse.RenderTransform>
                        <ScaleTransform CenterX="7" CenterY="7"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Grid>
        </Grid>

    </Grid>
</UserControl>
